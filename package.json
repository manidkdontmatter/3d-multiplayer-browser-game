{
  "name": "praeterspace-noctis-mundus",
  "version": "0.1.0",
  "description": "Praeterspace / Noctis Mundus authoritative first-person browser game scaffold (Three.js + Rapier + nengi 2.0)",
  "private": true,
  "scripts": {
    "check:boundaries": "tsx scripts/architecture-guards.ts",
    "assets:build:manifest": "tsx scripts/build-asset-manifest.ts",
    "assets:ensure:manifest": "tsx scripts/ensure-asset-manifest.ts",
    "dev": "concurrently -n CLIENT,SERVER -c cyan,green \"npm:dev:client\" \"npm:dev:server\"",
    "predev:client": "npm run assets:ensure:manifest",
    "dev:client": "vite",
    "dev:server": "tsx watch src/orchestrator/main.ts",
    "dev:server:single": "tsx watch src/game/server/main.ts",
    "build": "npm run build:client && npm run build:server",
    "prebuild:client": "npm run assets:build:manifest",
    "build:client": "vite build",
    "build:server": "tsup src/orchestrator/main.ts src/game/server/main.ts --format esm --target node20 --sourcemap --out-dir dist/server",
    "preview": "vite preview",
    "typecheck": "npm run check:boundaries && npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit --incremental --tsBuildInfoFile tsconfig.client.tsbuildinfo",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit --incremental --tsBuildInfoFile tsconfig.server.tsbuildinfo",
    "verify:quick": "npm run typecheck:client && npm run test:smoke:fast",
    "test:smoke": "node scripts/smoke-e2e.js",
    "test:smoke:fast": "node scripts/smoke-fast.js",
    "test:melee": "node scripts/melee-e2e.js",
    "test:projectile:damage": "node scripts/projectile-damage-e2e.js",
    "test:multiplayer": "npm run test:multiplayer:mode -- base",
    "test:transfer": "node scripts/transfer-e2e.js",
    "test:orchestrator:hardening": "node scripts/orchestrator-hardening-e2e.js",
    "profile:multiplayer:cpu:5s": "npm run test:multiplayer:mode -- profile-5s",
    "test:multiplayer:csp": "npm run test:multiplayer:mode -- csp",
    "test:multiplayer:chaos": "npm run test:multiplayer:mode -- chaos",
    "test:movement-parity": "tsx scripts/movement-parity.ts",
    "test:network-client:regression": "tsx scripts/network-client-regression.ts",
    "test:appearance:regression": "tsx scripts/appearance-system-regression.ts",
    "test:appearance:determinism": "tsx scripts/appearance-system-determinism-regression.ts",
    "test:pilot-seat:regression": "tsx scripts/pilot-seat-regression.ts",
    "test:tick": "tsx scripts/tick-consistency.ts",
    "test:npc:ai": "tsx scripts/npc-ai-regression.ts",
    "test:item-pickup:regression": "tsx scripts/item-pickup-regression.ts",
    "test:hotbar-payload:regression": "tsx scripts/hotbar-payload-regression.ts",
    "test:hotbar-input:regression": "tsx scripts/hotbar-input-regression.ts",
    "test:settings-save:regression": "tsx scripts/settings-save-regression.ts",
    "test:procedural:determinism": "tsx scripts/procedural-world-determinism.ts",
    "test:load:network": "node --import tsx scripts/network-load-split-profile.ts",
    "test:multiplayer:mode": "node scripts/multiplayer-mode.js",
    "test:ci": "npm run check:boundaries && npm run check:cycles && npm run typecheck:client && npm run typecheck:server && npm run test:tick && npm run test:network-client:regression && npm run test:appearance:regression && npm run test:appearance:determinism && npm run test:pilot-seat:regression && npm run test:hotbar-input:regression && npm run test:settings-save:regression && npm run test:procedural:determinism && npm run test:smoke:fast",
    "test:full": "npm run test:ci && npm run test:smoke && npm run test:melee && npm run test:projectile:damage && npm run test:transfer && npm run test:multiplayer:csp && npm run test:multiplayer:chaos && npm run test:orchestrator:hardening && npm run test:npc:ai && npm run test:load:network",
    "check:cycles": "madge --circular --extensions ts --ts-config tsconfig.base.json src/engine src/game src/orchestrator",
    "check:unused": "knip --config knip.json --no-progress",
    "test:network:full": "npm run test:network-client:regression && npm run test:multiplayer && npm run test:multiplayer:csp && npm run test:multiplayer:chaos && npm run test:load:network",
    "perf:load:100:sparse": "node --import tsx -e \"process.env.LOAD_PROFILE_CPU='0'; process.env.LOAD_CLIENTS='100'; process.env.LOAD_TOPOLOGY='sparse'; await import('./scripts/network-load-split-profile.ts');\"",
    "perf:load:100:clustered": "node --import tsx -e \"process.env.LOAD_PROFILE_CPU='0'; process.env.LOAD_CLIENTS='100'; process.env.LOAD_TOPOLOGY='clustered'; await import('./scripts/network-load-split-profile.ts');\"",
    "perf:load:100:profile:split": "node --import tsx -e \"process.env.LOAD_PROFILE_CPU='1'; process.env.LOAD_CLIENTS='100'; process.env.LOAD_TOPOLOGY='sparse'; await import('./scripts/network-load-split-profile.ts');\"",
    "perf:load:100:split": "node --import tsx -e \"process.env.LOAD_PROFILE_CPU='0'; process.env.LOAD_CLIENTS='100'; process.env.LOAD_TOPOLOGY='sparse'; await import('./scripts/network-load-split-profile.ts');\""
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "threejs",
    "rapier",
    "nengi",
    "authoritative-server",
    "fps"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "@pixiv/three-vrm": "3.4.5",
    "@pixiv/three-vrm-animation": "3.4.5",
    "better-sqlite3": "11.9.1",
    "bitecs": "0.4.0",
    "nengi": "2.0.0-alpha.173",
    "nengi-buffers": "0.5.0",
    "nengi-dataviews": "0.4.0",
    "nengi-websocket-client-adapter": "0.7.0",
    "recast-navigation": "0.43.1",
    "simplex-noise": "4.0.3",
    "three": "0.182.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.47.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.3.0",
    "@gltf-transform/core": "4.3.0",
    "@gltf-transform/extensions": "4.3.0",
    "@gltf-transform/functions": "4.3.0",
    "@types/node": "25.2.3",
    "@types/three": "0.182.0",
    "concurrently": "9.2.1",
    "fbx2vrma-converter": "1.0.2",
    "knip": "6.14.1",
    "ktx2-encoder": "0.5.1",
    "madge": "8.0.0",
    "meshoptimizer": "1.0.1",
    "playwright": "1.58.2",
    "sharp": "0.34.5",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
